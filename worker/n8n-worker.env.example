# ── Modo de execução ──────────────────────────────────────────────
EXECUTIONS_MODE=queue

# ── Banco de dados (PostgreSQL do master) ─────────────────────────
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=IP_PRIVADO_DO_MASTER        # IP interno GCP do servidor master
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=MESMA_SENHA_DO_MASTER   # igual a secrets/postgres_password.txt

# ── Redis (broker do master) ──────────────────────────────────────
QUEUE_BULL_REDIS_HOST=IP_PRIVADO_DO_MASTER     # mesmo host do Postgres
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=MESMA_SENHA_DO_MASTER # igual ao REDIS_PASSWORD do .env

# ── Segurança — DEVE ser idêntica ao master ───────────────────────
N8N_ENCRYPTION_KEY=MESMA_CHAVE_DO_MASTER       # copiada de n8n.env do master

# ── Concorrência ──────────────────────────────────────────────────
# Número de jobs simultâneos. Ajuste conforme o tamanho da VM.
# Mínimo recomendado pelo n8n: 5
N8N_CONCURRENCY_PRODUCTION_LIMIT=10

# ── Health check ──────────────────────────────────────────────────
QUEUE_HEALTH_CHECK_ACTIVE=true

# ── Ambiente ──────────────────────────────────────────────────────
NODE_ENV=production
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# ── Features (igual ao master) ────────────────────────────────────
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false

# ── Logs ──────────────────────────────────────────────────────────
N8N_LOG_LEVEL=info
