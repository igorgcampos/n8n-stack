# ── Modo de execução ──────────────────────────────────────────────
EXECUTIONS_MODE=queue

# ── Banco de dados (PostgreSQL) ───────────────────────────────────
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=DEFINA_IGUAL_A_secrets/postgres_password.txt

# ── Redis (broker da fila) ────────────────────────────────────────
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=DEFINA_IGUAL_AO_REDIS_PASSWORD_DO_.env

# ── Segurança ─────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=DEFINA_STRING_ALEATORIA_32_CHARS  # openssl rand -hex 16
# Gerar uma chave aleatória com: openssl rand -hex 16

# ── URL e acesso ──────────────────────────────────────────────────
N8N_HOST=n8n.editoraglobo.com.br
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.editoraglobo.com.br/
N8N_EDITOR_BASE_URL=https://n8n.editoraglobo.com.br/
N8N_PROXY_HOPS=1                      # 1 proxy na frente (nginx)

# ── Ambiente ──────────────────────────────────────────────────────
NODE_ENV=production
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# ── Features ──────────────────────────────────────────────────────
N8N_RUNNERS_ENABLED=true
N8N_DIAGNOSTICS_ENABLED=false

# ── Logs ──────────────────────────────────────────────────────────
N8N_LOG_LEVEL=info
